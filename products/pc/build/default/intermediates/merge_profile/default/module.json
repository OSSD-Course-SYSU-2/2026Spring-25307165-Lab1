{
	"app": {
		"bundleName": "com.example.multidevicecommunication",
		"vendor": "example",
		"versionCode": 1000000,
		"versionName": "1.0.0",
		"buildVersion": "1",
		"icon": "$media:layered_image",
		"label": "$string:app_name",
		"apiReleaseType": "Release",
		"compileSdkVersion": "6.1.1.125",
		"targetAPIVersion": 60100023,
		"minAPIVersion": 60002022,
		"compileSdkType": "HarmonyOS",
		"targetMinorAPIVersion": 0,
		"targetPatchAPIVersion": 0,
		"appEnvironments": [],
		"bundleType": "app",
		"buildMode": "debug",
		"debug": true
	},
	"module": {
		"name": "multidevicecommunicationpcsample",
		"type": "entry",
		"description": "$string:module_desc",
		"mainElement": "MultidevicecommunicationpcAbility",
		"deviceTypes": [
			"2in1"
		],
		"deliveryWithInstall": true,
		"installationFree": false,
		"pages": "$profile:main_pages",
		"abilities": [
			{
				"name": "MultidevicecommunicationpcAbility",
				"srcEntry": "./ets/pcability/PcAbility.ets",
				"description": "$string:PcAbility_desc",
				"icon": "$media:layered_image",
				"label": "$string:PcAbility_label",
				"startWindowIcon": "$media:startIcon",
				"startWindowBackground": "$color:start_window_background",
				"exported": true,
				"minWindowWidth": 1080,
				"minWindowHeight": 500,
				"skills": [
					{
						"entities": [
							"entity.system.home"
						],
						"actions": [
							"ohos.want.action.home"
						]
					}
				]
			}
		],
		"extensionAbilities": [
			{
				"name": "PcBackupAbility",
				"srcEntry": "./ets/pcbackupability/PcBackupAbility.ets",
				"type": "backup",
				"exported": false,
				"metadata": [
					{
						"name": "ohos.extension.backup",
						"resource": "$profile:backup_config"
					}
				]
			}
		],
		"packageName": "multidevicecommunicationpcsample"
	}
}
