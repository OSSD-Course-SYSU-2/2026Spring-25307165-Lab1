{
  "app": {
    "signingConfigs": [],
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "targetSdkVersion": "5.0.3(15)",
        "compatibleSdkVersion": "5.0.3(15)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug"
      },
      {
        "name": "release"
      }
    ]
  },
  "modules": [
    {
      "name": "common_lib",
      "srcPath": "./commons/common_lib",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    {
      "name": "todo",
      "srcPath": "./scenes/todo"
    },
    {
      "name": "network",
      "srcPath": "./commons/network"
    },
    {
      "name": "calendar",
      "srcPath": "./scenes/calendar"
    },
    {
      "name": "component_lib",
      "srcPath": "./commons/component_lib"
    },
    {
      "name": "calendar_component",
      "srcPath": "./components/calendar_component"
    },
    {
      "name": "phone",
      "srcPath": "./products/phone",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    }
  ]
}